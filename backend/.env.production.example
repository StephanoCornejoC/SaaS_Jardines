# ==========================================
# PRODUCTION ENV VARS - SaaS Kiddo (miniddo.com)
# ==========================================
# Configurar estos valores en Railway Dashboard → Service → Variables.
# NUNCA commitear el .env real al repositorio.
#
# Variables que Railway inyecta automáticamente vía service-to-service
# (referenciar como ${{Postgres.NOMBRE}} en la UI de variables):
#   - PGDATABASE, PGUSER, PGPASSWORD, PGHOST, PGPORT
#   - DATABASE_URL (Railway lo arma solo, opcional)
#   - PORT (el puerto en que escucha gunicorn)
#   - RAILWAY_GIT_COMMIT_SHA (release tag para Sentry)

# ------- Django core -------
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generar con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=REEMPLAZAR_CON_KEY_GENERADA
DEBUG=False
# Dominios desde donde se acepta tráfico
ALLOWED_HOSTS=.railway.app,.miniddo.com

# ------- Multi-tenant (Kiddo) -------
TENANT_BASE_DOMAIN=miniddo.com
SUPERADMIN_EMAIL=stephano.cornejoc@gmail.com

# ------- CORS / CSRF (Frontend Vercel + admin Django) -------
# Dejar el placeholder vercel.app hasta el deploy en D9
CORS_ALLOWED_ORIGINS=https://app.miniddo.com,https://kiddo-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://app.miniddo.com,https://*.miniddo.com,https://kiddo-app.vercel.app

# ------- Email SMTP (Brevo) -------
# Crear cuenta gratis en https://app.brevo.com (D6)
# Después de validar el dominio, en Brevo → Senders & IP → SMTP & API
# obtenés un usuario SMTP (típicamente tu email) y una "SMTP key".
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=PENDIENTE_BREVO_D6
EMAIL_HOST_PASSWORD=PENDIENTE_BREVO_SMTP_KEY_D6
DEFAULT_FROM_EMAIL=noreply@miniddo.com

# ------- Cobro mensual al jardín (PlatformInvoice) -------
COREM_BUSINESS_NAME=COREM Labs S.A.C.
COREM_YAPE_PHONE=
COREM_PLIN_PHONE=

# ------- Cron diario (D7: GitHub Actions llama endpoint protegido por este token) -------
# Generar con: openssl rand -hex 32  (o cualquier secret manager)
CRON_SECRET_TOKEN=REEMPLAZAR_CON_TOKEN_HEX_64_CHARS

# ------- Monitoring (D8: Sentry free tier) -------
# Dejar vacío hasta crear la cuenta Sentry. Si SENTRY_DSN está vacío, Django
# arranca sin error reporting (no rompe).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ------- JWT (auth) -------
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=1
