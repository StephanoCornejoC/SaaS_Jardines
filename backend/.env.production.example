# ==========================================
# PRODUCTION ENV VARS - SAAS COREM Backend (Railway)
# ==========================================
# Copia estas variables a Railway Dashboard > Variables
# NUNCA commitear el .env real al repositorio

# ------- Django -------
DJANGO_SETTINGS_MODULE=config.settings.prod
# Genera con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=REEMPLAZAR_CON_KEY_GENERADA
DEBUG=False
ALLOWED_HOSTS=.railway.app,api.corem.pe,admin.corem.pe

# ------- PostgreSQL -------
# Railway lo inyecta auto al añadir el plugin Postgres:
# PGHOST, PGUSER, PGPASSWORD, PGPORT, PGDATABASE

# ------- Redis (opcional, solo si usas Celery worker en background) -------
# REDIS_URL=${{Redis.REDIS_URL}}    # auto via Railway plugin

# ------- CORS / CSRF (separar por coma, sin espacios) -------
CORS_ALLOWED_ORIGINS=https://app.corem.pe,https://corem-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://app.corem.pe,https://corem-frontend.vercel.app,https://admin.corem.pe

# ------- JWT -------
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=1

# ------- Email SMTP (Gmail con app password) -------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tunotificador@gmail.com
EMAIL_HOST_PASSWORD=app_password_de_gmail_16_caracteres
DEFAULT_FROM_EMAIL=noreply@corem.pe

# Email del SuperAdmin que recibe notificaciones automáticas
# (vencimientos de trial y cobros próximos)
SUPERADMIN_EMAIL=tu_correo@corem.pe

# ------- Monitoring (Sentry free tier — opcional) -------
# SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/zzzzz
# SENTRY_ENVIRONMENT=production

# ------- Tenant base domain (al crear jardines, default xxx.corem.pe) -------
TENANT_BASE_DOMAIN=corem.pe

# ------- Storage -------
MEDIA_URL=/media/
STATIC_URL=/static/
