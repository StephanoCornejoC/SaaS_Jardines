# ==========================================
# PRODUCTION ENV VARS - SAAS COREM Backend
# ==========================================
# Copia este archivo a .env en Railway Dashboard
# NUNCA commitear el .env real al repositorio

# ------- Django -------
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=REEMPLAZAR_CON_KEY_GENERADA_CON_get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=.railway.app,api.corem.pe

# ------- Database (Railway lo inyecta automaticamente) -------
# DATABASE_URL=${{Postgres.DATABASE_URL}}   # auto
# PGHOST, PGUSER, PGPASSWORD, PGPORT, PGDATABASE   # auto

# ------- Redis (Railway lo inyecta automaticamente) -------
# REDIS_URL=${{Redis.REDIS_URL}}   # auto

# ------- CORS / CSRF -------
CORS_ALLOWED_ORIGINS=https://tuapp.vercel.app,https://app.corem.pe
CSRF_TRUSTED_ORIGINS=https://tuapp.vercel.app,https://app.corem.pe

# ------- JWT -------
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=1

# ------- Email SMTP (Gmail con app password) -------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tunotificador@gmail.com
EMAIL_HOST_PASSWORD=app_password_de_gmail_16_caracteres
DEFAULT_FROM_EMAIL=noreply@corem.pe

# ------- Monitoring (Sentry free tier) -------
SENTRY_DSN=https://xxxxx@yyyyy.ingest.sentry.io/zzzzz
SENTRY_ENVIRONMENT=production

# ------- Jazzmin admin -------
DJANGO_ADMIN_URL=corem-panel-x9k2

# ------- Storage -------
MEDIA_URL=/media/
STATIC_URL=/static/
